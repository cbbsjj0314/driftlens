# DriftLens real LLM smoke test configuration
# Copy this file to .env and fill in values locally.
# Do not commit .env.

# Required for --analysis-provider openai-compatible
LLM_API_KEY=
LLM_MODEL=

# Optional.
# Use this only when calling an OpenAI-compatible provider
# that needs a custom base URL.
# Examples:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_BASE_URL=https://api.deepseek.com
LLM_BASE_URL=
